          "recommended_placement": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "publish_checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checklist_item", "status", "owner_note"],
        "properties": {
          "checklist_item": { "type": "string" },
          "status": { "type": "string" },
          "owner_note": { "type": "string" }
