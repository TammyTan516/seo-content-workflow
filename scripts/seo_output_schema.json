      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["order", "section_type", "heading", "target_keywords", "purpose_notes"],
        "properties": {
          "order": { "type": "integer" },
          "section_type": { "type": "string" },
          "heading": { "type": "string" },
          "target_keywords": { "type": "string" },
          "purpose_notes": { "type": "string" }
        }
      }
