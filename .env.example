AI_PROVIDER=codex

# Only needed when AI_PROVIDER=compatible
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# Optional: choose a Codex model. Leave blank to use your Codex default.
CODEX_MODEL=
CODEX_CLI_BIN=

# SEO流程化自动更新
SEO_SPREADSHEET_TOKEN=your_feishu_spreadsheet_token
SEO_HOT_SHEET_ID=your_hot_topic_sheet_id
SEO_BLOG_SHEET_ID=your_blog_review_sheet_id
SEO_CONFIG_SHEET_ID=your_seo_config_sheet_id
SEO_STRATEGY_SHEET_ID=your_strategy_sheet_id
SEO_MAX_ROWS=200
SEO_HOT_SOURCE_LIMIT=6
SEO_ENABLE_GOOGLE_NEWS=false

# Optional: put generated SEO Revised Docs under a specific Feishu folder/wiki parent.
SEO_REVISED_DOC_PARENT_TOKEN=
FEISHU_DOC_BASE_URL=https://www.feishu.cn/docx

# Optional: pin a local lark-cli binary.
LARK_CLI_BIN=
